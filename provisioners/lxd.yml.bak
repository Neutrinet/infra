- hosts: localhost
  # run this task in the host
  connection: local
  tasks:
  - name: create containers
    # get all host names from inventory
    loop: "{{ groups.all }}"
    loop_control:
      loop_var: host
    # use lxd_container module from ansible to create containers
    lxd_container:
      # container name is the hostname
      name: "{{ host.split('.') | first }}"
      state: started
      source:
        type: image
        mode: pull
        server: https://images.linuxcontainers.org
        alias: debian/buster/cloud/amd64
        protocol: simplestreams
      profiles:
      - default
      config:
        user.user-data: |
            #cloud-config

            # Apply updates using apt
            package_upgrade: true

            # Set hostname
            hostname: web
            fqdn: web.neutri.net.local
            manage_etc_hosts: true

            # Install packages
            packages:
            - ssh

            # User setup
            users:
            - name: raoul
              ssh-authorized-keys:
              - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDj0v/tuESuf0EhMudYFkASpuzrBOoYqul5lcYjz2ob0 hadrien@terry"
              sudo: ['ALL=(ALL) NOPASSWD:ALL']
              groups: sudo
              shell: /bin/bash
        user.network-config: |
            version: 1
            config:
            - type: physical
              name: eth0
              subnets:
              - type: static
                ipv4: true
                address: {{ hostvars[host].ansible_host }}
            - type: nameserver
              address: 8.8.8.8
        security.nesting: 'true' 
        security.privileged: 'false'
      devices:
        # configure network interface
        eth0:
          type: nic
          nictype: bridged
          parent: lxdbr0
          ipv4.address: "{{ hostvars[host].ansible_host }}"

      # uncomment if you installed lxd using snap
      # url: unix:/var/snap/lxd/common/lxd/unix.socket
      wait_for_ipv4_addresses: true
      timeout: 600
    #register: containers
  #- debug:
      #var: containers.results
  #- name: Config /etc/hosts file accordingly
    #lineinfile:
      #path: /etc/hosts
      #regexp: ".*{{ container.host }}$"
      #line: "{{ container.addresses.eth0 | first }}    {{ container.host }}"
      #state: "present"
